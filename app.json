{
  "expo": {
    "name": "IronHabit",
    "slug": "ironhabit",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon_black.png",
    "userInterfaceStyle": "dark",
    "scheme": "ironhabit",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "icon": "./assets/icon_black.png",
      "infoPlist": {
        "UIViewControllerBasedStatusBarAppearance": true
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon_black.png",
        "backgroundColor": "#FFFFFF"
      }
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-audio",
      "expo-asset"
    ]
  }
}
